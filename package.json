{
  "name": "eslint-plugin-a11y-enforce",
  "version": "0.2.0",
  "description": "ESLint plugin that catches accessibility composition errors that element-level tools miss.",
  "author": "Venkatesh Mukundan <vmvenkatesh78@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vmvenkatesh78/eslint-plugin-a11y-enforce"
  },
  "homepage": "https://github.com/vmvenkatesh78/eslint-plugin-a11y-enforce#readme",
  "bugs": "https://github.com/vmvenkatesh78/eslint-plugin-a11y-enforce/issues",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "accessibility",
    "a11y",
    "aria",
    "wcag",
    "react",
    "jsx"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
